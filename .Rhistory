}
for (var in variables_a_corriger) {
if (var %in% names(data)) {
comparer_stats(data[[var]], health_clean[[var]], var)
}
}
# --- Visualisation ---
data_compare <- data.frame()
for (var in variables_a_corriger) {
temp <- data.frame(
Valeur   = c(data[[var]], health_clean[[var]]),
Variable = var,
Statut   = rep(c("Avant", "Après"), each = nrow(data))
)
data_compare <- rbind(data_compare, temp)
}
ggplot(data_compare, aes(x = Variable, y = Valeur, fill = Statut)) +
geom_boxplot() +
labs(
title = "Comparaison avant / après correction des valeurs aberrantes",
x = "Variables",
y = "Valeurs"
) +
theme_minimal()
# --- Sauvegarde ---
write.csv(health_clean, "health_dataset_clean.csv", row.names = FALSE)
cat("\nRAPPORT FINAL\n")
cat("====================================\n")
cat("Observations totales :", nrow(health_clean), "\n")
cat("Variables nettoyées  :", length(variables_numeriques), "\n")
cat("Fichier sauvegardé   : health_dataset_clean.csv\n")
cat("Nettoyage terminé avec succès !\n\n")
print(head(health_clean))
library(ggplot2)
target_vars <- c(
"hand_grip_strength_kg",
"sit_and_reach_cm",
"sit_ups_count",
"vo2_estimate_ml_per_kg_min"
)
for (var in target_vars) {
cat("--------------------------------------------------\n")
cat("Variable :", var, "\n")
cat("--------------------------------------------------\n\n")
x <- health_clean[[var]]
print(summary(x))
mean_x <- mean(x, na.rm = TRUE)
sd_x   <- sd(x, na.rm = TRUE)
df_var <- data.frame(x = x)
# Histogramme + densité
p1 <- ggplot(df_var, aes(x)) +
geom_histogram(aes(y = ..density..), bins = 30,
fill = "lightblue", alpha = 0.6) +
geom_density(color = "red", linewidth = 1.2) +
stat_function(fun = dnorm,
args = list(mean = mean_x, sd = sd_x),
color = "darkgreen", linewidth = 1.2) +
theme_minimal() +
labs(title = paste("Distribution —", var), x = var, y = "Densité")
print(p1)
# QQ Plot
p2 <- ggplot(df_var, aes(sample = x)) +
stat_qq(color = "blue") +
stat_qq_line(color = "red") +
theme_minimal() +
labs(title = paste("QQ Plot —", var))
print(p2)
# Test de Shapiro-Wilk
if (length(na.omit(x)) <= 5000) {
sh <- shapiro.test(x)
print(sh)
} else {
cat("Test de Shapiro-Wilk non applicable (n > 5000 observations)\n")
}
cat("\n\n")
}
